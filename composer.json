{
	"name": "phpgt/orm",
	"description": "Object relational mapper.",
	"license": "MIT",
	"require": {
		"phpgt/sqlbuilder": "dev-master",
		"phpgt/database": "dev-master"
	},
	"require-dev": {
		"phpstan/phpstan": "^1.10",
		"phpunit/phpunit": "^13.1",
		"phpmd/phpmd": "^2.13",
		"squizlabs/php_codesniffer": "^3.7"
	},

	"autoload": {
		"psr-4": {
			"GT\\Orm\\": "./src",
			"Gt\\Orm\\": "./src"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"GT\\Orm\\Test\\": "./test/phpunit",
			"Gt\\Orm\\Test\\": "./test/phpunit"
		}
	},
	"scripts": {
		"phpunit": "vendor/bin/phpunit --configuration phpunit.xml",
		"phpstan": "vendor/bin/phpstan analyse --level 6 --memory-limit 1G src",
		"phpcs": "vendor/bin/phpcs src --standard=phpcs.xml",
		"phpmd": "vendor/bin/phpmd src/ text phpmd.xml",
		"test": [
			"@phpunit",
			"@phpstan",
			"@phpcs",
			"@phpmd"
		]
	},
	"keywords": [
		"orm",
		"object relational mapper",
		"database",
		"entity",
		"repository",
		"repo",
		"sql",
		"nosql",
		"mapping",
		"pdo",
		"crud",
		"query",
		"relational",
		"data persistence",
		"data mapper",
		"migration",
		"schema"
	],
	"funding": [
		{
			"type": "github",
			"url": "https://github.com/sponsors/PhpGt"
		}
	]
}
